# Django CRM API (required for --upload)
API_BASE_URL=https://3pillars.pythonanywhere.com/api

# Single company (legacy):
# API_USERNAME=your_username
# API_PASSWORD=your_password
# COMPANY_SLUG=past-and-present

# Multiple companies with per-company credentials (aligned by index):
COMPANY_SLUGS=past-and-present,javamellow,plant-sanctuary
API_USERNAMES=user1,user2,user3
API_PASSWORDS=pass1,pass2,pass3

# Category for each company (run --list-categories to get IDs)
# Format: slug:uuid or slug:uuid,slug:uuid
CATEGORY_IDS=past-and-present:49742736-01e4-43a6-a730-20218aab6a24

# Optional
HEADLESS=true
# If API uses email instead of username for login:
# API_USE_EMAIL=true

# Orders page: Courier Guy (after goods arrive)
COURIER_GUY_API_KEY=
COURIER_GUY_API_BASE_URL=https://api.portal.thecourierguy.co.za
COURIER_COLLECTION_STREET=
COURIER_COLLECTION_SUBURB=
COURIER_COLLECTION_CITY=
COURIER_COLLECTION_PROVINCE=GP
COURIER_COLLECTION_POSTAL=
COURIER_COLLECTION_NAME=
COURIER_COLLECTION_EMAIL=
COURIER_COLLECTION_PHONE=

# Orders page: Yoco session (browser profile path)
YOCO_PROFILE_PATH=products/yoco/chrome_profile
